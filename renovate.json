{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpgradeTasks": {
    "commands": ["bundle install"],
    "fileFilters": ["Gemfile.lock"],
    "executionMode": "branch"
  },
  "packageRules": [
    {
      "matchManagers": [
        "bundler"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "groupName": "ruby dependencies (non-major)"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "major"
      ],
      "groupName": "github actions"
    }
  ]
}
